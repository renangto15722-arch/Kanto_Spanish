{   
    "speakers": {
        "npc": {
          "name": "Oak's Aide",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:scientistm",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'Oh, hola, ' + q.player.username + '! ¿Cómo te va?';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Soy yo, uno de los ayudantes del Prof. Oak."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¿Conociste al otro ayudante?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'Tenía un paquete del Prof. Oak para ti, ' + q.player.username + '.';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'Dijo que te buscaría por la Ruta 2, ' + q.player.username + '.';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "Si estás por la zona de la Ruta 2, por favor búscalo."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }
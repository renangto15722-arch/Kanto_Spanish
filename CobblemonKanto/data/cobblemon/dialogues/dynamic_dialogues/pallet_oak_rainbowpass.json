{   
    "speakers": {
        "npc": {
          "name": "Porfessor Oak",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:oak",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",

            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "blue",
            "lines": [
                "¡Me convertiré en el Entrenador más poderoso del mundo!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "blue",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'' + q.player.username + ', ¡bueno, buena suerte! ¡No te preocupes!';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }

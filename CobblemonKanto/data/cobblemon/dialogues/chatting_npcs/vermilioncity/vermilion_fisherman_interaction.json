{   
    "speakers": {
        "npc": {
          "name": "Fishing Guru",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:fisherman",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Soy el Fishing Guru! ¡Simplemente adoooro pescar! No puedo pasar sin ello."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Dime, ¿te gusta pescar?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¡Estupendo! Me gusta tu estilo. Creo que podemos ser amigos. ¡Toma esto y pesca, joven amigo!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "De los mares a los ríos, sal y pesca al grande, amigo mío."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run function kanto:triggers/itemlootgive');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }
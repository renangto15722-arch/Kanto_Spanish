{   "initializationAction": [              
    "c.npc.set_chatting();",
    "q.run_command('scoreboard players set ' + q.player.username + ' BattleEnd 1');",
    "q.run_command('execute as ' + q.player.username + ' run function kanto:triggers/stopsound');",
    "q.run_command('tellraw ' + q.player.username + ' {\"text\":\"¡Ganaste $288 por la victoria!\",\"italic\":true,\"color\":\"gray\"}');",
    "q.run_command('scoreboard players add ' + q.player.username + ' Money 288');"
        ],
    "escapeAction": [],
    "speakers": {
        "oak": {
            "name": "Professor Oak",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:oak",
                "isLeftSide": true
            }
        },
        "blue": {
            "name": "Blue",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:blue",
                "isLeftSide": false
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "blue",
            "lines": [
                "Oye, ¿a que no sabes?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "blue",
            "lines": [
                "Fui a casa de Bill y conseguí que me mostrara sus Pokémon raros."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "blue",
            "lines": [
                "¡Eso añadió muchas páginas a mi Pokédex!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "blue",
            "lines": [
                "Después de todo, Bill es famoso en todo el mundo como Pokémaníaco."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "blue",
            "lines": [
                "También inventó el Sistema de Almacenamiento Pokémon en el PC."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "blue",
            "lines": [
                "Ya que usas su sistema, deberías ir a darle las gracias."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "blue",
            "lines": [
                "¡Bueno, será mejor que me vaya! ¡Nos vemos!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('particle cloud 3107 34 950 1 1 1 1 75');",
                            "q.run_command('tp @e[x=3107,y=33,z=950,dy=3,type=cobblemon:npc] 10000000 -50000 -10000000');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue23');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}
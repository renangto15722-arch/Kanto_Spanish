{
    "initializationAction": [
        "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 4');",
        "q.run_command('execute as ' + q.player.username + ' run function kanto:triggers/stopsound');",
        "q.run_command('execute as ' + q.player.username + ' run tag @s add InDialogue');"
    ],
    "escapeAction": [
    ],
    "names": [
        "Blue"
    ],
    "speakers": {
        "npc": {
            "name": {
                "type": "expression",
                "expression": "q.npc.name"
            },
            "face": "q.npc.face();"
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'¡Oye! ' + q.player.username + '!';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "¿Qué haces aquí en las Islas Sete?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Deberías dejar de copiarme, ¿sabes?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "En fin, ya conseguí mi Pokémon Egg, así que terminé con esta isla."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "Je, apuesto a que ni siquiera sabes sobre los Pokémon Eggs."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "Nunca llenarás tu Pokédex Nacional de esa manera."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "npc",
            "lines": [
                "Por cierto, vi a alguien que ambos conocemos en esta isla."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page8');"
                    }
                ]
            }
        },
        {
            "id": "page8",
            "speaker": "npc",
            "lines": [
                "¿Por qué no vas a echar un vistazo si te da curiosidad?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page9');"
                    }
                ]
            }
        },
        {
            "id": "page9",
            "speaker": "npc",
            "lines": [
                "Yo no tengo tiempo que perder."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page10');"
                    }
                ]
            }
        },
        {
            "id": "page10",
            "speaker": "npc",
            "lines": [
                "¡Nos olemos luego!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 0');",
                            "q.run_command('particle cloud 4367 34 -3342 1 1 1 1 75');",
                            "q.run_command('tp @e[x=4367,y=34,z=-3342,dy=3,type=cobblemon:npc] 10000000 -50000 -10000000');",
                            "q.run_command('execute as ' + q.player.username + ' run function kanto:triggers/stopsound');",
                            "q.run_command('execute as ' + q.player.username + ' run tag @s remove InDialogue');",
                            "q.run_command('execute as ' + q.player.username + ' run tag @s add Dialogue113');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
    ]
}
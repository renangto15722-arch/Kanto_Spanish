{
    "initializationAction": [
        "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 4');",
        "q.run_command('execute as ' + q.player.username + ' run function kanto:triggers/stopsound');",
        "q.run_command('execute as ' + q.player.username + ' run tag @s add InDialogue');"
    ],
    "escapeAction": [
    ],
    "names": [
        "Blue"
    ],
    "speakers": {
        "npc": {
            "name": {
                "type": "expression",
                "expression": "q.npc.name"
            },
            "face": "q.npc.face();"
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'¡Hola, ' + q.player.username + '! ¿Cómo va llenándose tu Pokédex?';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Parece que es imposible conseguir todos los Pokémon quedándote solo por estos lugares."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Quizás haya Pokémon que no conocemos en algún lugar lejano..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "... ... ... ... ... ... ... ... ..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "Bueno, si yo no puedo hacerlo, no hay forma de que tú lo logres."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "No voy a desesperarme por esto."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "npc",
            "lines": [
                "Seguiré coleccionando Pokémon a mi propio ritmo mientras los entreno."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page8');"
                    }
                ]
            }
        },
        {
            "id": "page8",
            "speaker": "npc",
            "lines": [
                "Eso es lo que haré. Así que no tiene sentido quedarme aquí."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page9');"
                    }
                ]
            }
        },
        {
            "id": "page9",
            "speaker": "npc",
            "lines": [
                "Más vale que vuelva a casa. ¡Y con esto, se acabó!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page10');"
                    }
                ]
            }
        },
        {
            "id": "page10",
            "speaker": "npc",
            "lines": [
                "¡Nos vemos!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 0');",
                            "q.run_command('particle cloud 2836 40 -4316 1 1 1 1 75');",
                            "q.run_command('tp @e[x=2836,y=40,z=-4316,dy=3,type=cobblemon:npc] 10000000 -50000 -10000000');",
                            "q.run_command('execute as ' + q.player.username + ' run function kanto:triggers/stopsound');",
                            "q.run_command('execute as ' + q.player.username + ' run tag @s remove InDialogue');",
                            "q.run_command('execute as ' + q.player.username + ' run tag @s add Dialogue116');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
    ]
}
{   
    "speakers": {
        "npc": {
          "name": "Shopkeeper",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:shopman",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Hola! Trabajo en una Tienda Pokémon. "
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Es parte de una práctica cadena que vende todo tipo de objetos."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Por favor, visítanos en Ciudad Verde. Ya sé, te daré una muestra. ¡Aquí tienes!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "Ven a vernos si necesitas Poké Balls para atrapar Pokémon."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run function kanto:triggers/itemlootgive');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }
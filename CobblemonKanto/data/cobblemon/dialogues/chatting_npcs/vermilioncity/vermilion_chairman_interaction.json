{
    "speakers": {
        "npc": {
            "name": "Fanclub Chairman",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:gentleman",
                "isLeftSide": true
            }
        },
        "player": {
            "face": "q.player.face(true);",
            "name": {
                "type": "expression",
                "expression": "q.player.username"
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Yo presido el Pokémon Fan Club!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "¡Crío más de cien Pokémon!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¡Soy muy exigente cuando se trata de Pokémon! ¡De verdad que sí!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "Entonces... ¿Viniste a escuchar sobre mis Pokémon?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Yes",
                        "value": "yes",
                        "action": "q.dialogue.set_page('page6');"
                    },
                    {
                        "text": "No",
                        "value": "no",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "Oh. ¡Vuelve cuando quieras escuchar mi historia!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "¡Bien! ¡Entonces escucha!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "npc",
            "lines": [
                "Mi Rapidash favorito..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page8');"
                    }
                ]
            }
        },
        {
            "id": "page8",
            "speaker": "npc",
            "lines": [
                "Es...tierno...encantador...listo..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page9');"
                    }
                ]
            }
        },
        {
            "id": "page9",
            "speaker": "npc",
            "lines": [
                "además...asombroso...¿no crees?..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page10');"
                    }
                ]
            }
        },
        {
            "id": "page10",
            "speaker": "npc",
            "lines": [
                "oh sí...es...impresionante..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page11');"
                    }
                ]
            }
        },
        {
            "id": "page11",
            "speaker": "npc",
            "lines": [
                "adorable... ¡me encanta!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page12');"
                    }
                ]
            }
        },
        {
            "id": "page12",
            "speaker": "npc",
            "lines": [
                "Lo abrazo...cuando...duerme...calentito y mimoso..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page13');"
                    }
                ]
            }
        },
        {
            "id": "page13",
            "speaker": "npc",
            "lines": [
                "espectacular... deslumbrante..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page14');"
                    }
                ]
            }
        },
        {
            "id": "page14",
            "speaker": "npc",
            "lines": [
                "...¡Ups! ¡Mira la hora! ¡Te entretuve demasiado!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page15');"
                    }
                ]
            }
        },
        {
            "id": "page15",
            "speaker": "npc",
            "lines": [
                "¡Gracias por escucharme! ¡Quiero que tengas esto!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run playsound getitem ambient @s ~ ~ ~ 1 1 1');",
                            "q.run_command('execute as ' + q.player.username + ' run tag @s add Dialogue37');",
                            "q.dialogue.set_page('page16');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page16",
            "speaker": "player",
            "lines": [
                "Recibiste un Bike Voucher del Chairman."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page17');"
                    }
                ]
            }
        },
        {
            "id": "page17",
            "speaker": "npc",
            "lines": [
                "Lleva ese Bike Voucher a la Bike Shop en Ciudad Celeste."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page18');"
                    }
                ]
            }
        },
        {
            "id": "page18",
            "speaker": "npc",
            "lines": [
                "¡Cámbialo por una bicicleta gratis!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page19');"
                    }
                ]
            }
        },
        {
            "id": "page19",
            "speaker": "npc",
            "lines": [
                "No te preocupes, mi Fearow favorito me llevará volando a donde necesite ir."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page20');"
                    }
                ]
            }
        },
        {
            "id": "page20",
            "speaker": "npc",
            "lines": [
                "Así que no necesito una bicicleta. ¡Espero que disfrutes andar en bici!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}
{   
    "speakers": {
        "npc": {
          "name": "     ",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:gentleman",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "Viajas por todas partes, ¿verdad? No estarás exigiendo demasiado a tus Pokémon, ¿o sí?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Déjame echar un vistazo. … … … … … … Ah, mmm… Ya veo, ya veo…"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Oh, impresionante. Tratas bien a tus Pokémon. Creo que puedo confiarte esto."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "Por favor, me gustaría que tengas esto. Me alegra haber conocido a alguien como tú."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run function kanto:triggers/itemlootgive');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }